#  Edge case: Shodan sees things DNS doesn't.
#  Old services, SSL certs pointing to internal domains,
#  same app running somewhere without a WAF.
# ════════════════════════════════════════════════════════════
shodan_intel(){
    printf "\n" && info "Shodan Intelligence for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/ports"

    [ -z "$SHODAN_API_KEY" ] && warn "Set SHODAN_API_KEY in config." && return 1
