# ════════════════════════════════════════════════════════════
#  12. GF PATTERNS — INSTANT VULN SIGNAL FROM URL LIST
#  Edge case: run gf on your collected URLs to instantly
#  surface XSS, SQLi, SSRF, LFI, IDOR, SSTI candidate URLs.
#  This is the fastest triage step before manual testing.
# ════════════════════════════════════════════════════════════
gf_patterns(){
    printf "\n" && info "GF Pattern Matching on all collected URLs"
    local OUT="$OUTPUT_DIR/patterns"
    local URLS="$OUTPUT_DIR/urls/all_urls.txt"

    require gf || return 1
    [ ! -f "$URLS" ] && warn "Run -url first." && return 1

    local patterns=("xss" "sqli" "ssrf" "redirect" "lfi" "rce" "idor" "ssti"
                    "debug_logic" "cors" "upload-fields" "interestingparams" "img-traversal")

    for pattern in "${patterns[@]}"; do
        local result
        result=$(cat "$URLS" | gf "$pattern" 2>/dev/null)
        if [ -n "$result" ]; then
            echo "$result" > "$OUT/gf_${pattern}.txt"
            local count=$(echo "$result" | wc -l)
            step "gf $pattern → $count candidate URLs"
            case "$pattern" in
                ssrf|rce) [ "$count" -gt 0 ] && notify "HIGH: gf $pattern found $count candidates!" ;;
            esac
        fi
    done

    step "Compiling summary..."
    echo "## GF Pattern Summary" > "$OUT/gf_summary.txt"
    for f in "$OUT"/gf_*.txt; do
        local name count
        name=$(basename "$f" .txt | sed 's/gf_//')
        count=$(wc -l < "$f")
        echo "- $name: $count URLs" >> "$OUT/gf_summary.txt"
    done
    cat "$OUT/gf_summary.txt"

    success "GF patterns done. Investigate $OUT/gf_*.txt"
}


# ════════════════════════════════════════════════════════════
#  13. CORS MISCONFIGURATION
#  Edge case: CORS on API subdomains is extremely common
#  and consistently pays. Null origin bypass is often missed.
# ════════════════════════════════════════════════════════════
cors_check(){
    printf "\n" && info "CORS Misconfiguration Check for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/cors"
    local LIVE="$OUTPUT_DIR/subdomains/live_hosts.txt"

    step "Running Corsy on live hosts..."
    if require corsy.py && [ -f "$LIVE" ]; then
        awk '{print $1}' "$LIVE" | head -50 | while IFS= read -r url; do
            python3 corsy.py -u "$url" -t 10 2>/dev/null >> "$OUT/corsy_raw.txt"
        done
        grep -i "vuln\|misconfiguration\|null\|reflect" "$OUT/corsy_raw.txt" 2>/dev/null \
            > "$OUT/cors_vulns.txt"
    fi

    step "Manual reflect + credentials check..."
    [ -f "$LIVE" ] && awk '{print $1}' "$LIVE" | head -30 | while IFS= read -r url; do
        # Reflected origin with credentials
        resp=$(curl -s -I -H "Origin: https://evil.com" "$url" 2>/dev/null)
        if echo "$resp" | grep -qi "access-control-allow-origin: https://evil.com"; then
            if echo "$resp" | grep -qi "access-control-allow-credentials: true"; then
                alert "CORS+CREDENTIALS at $url — HIGH severity!"
                echo "CORS_CRED: $url" >> "$OUT/cors_vulns.txt"
                notify "CORS + credentials at $url!"
            else
                echo "CORS_REFLECT: $url" >> "$OUT/cors_vulns.txt"
            fi
        fi

        # Null origin bypass
        resp2=$(curl -s -I -H "Origin: null" "$url" 2>/dev/null)
        echo "$resp2" | grep -qi "access-control-allow-origin: null" && {
            alert "NULL origin CORS bypass at $url!"
            echo "CORS_NULL: $url" >> "$OUT/cors_vulns.txt"
            notify "Null origin CORS bypass at $url!"
        }

        # Subdomain origin bypass (trusts *.target.com — attacker controls a subdomain = win)
        resp3=$(curl -s -I -H "Origin: https://evil.$target" "$url" 2>/dev/null)
        echo "$resp3" | grep -qi "access-control-allow-origin: https://evil.$target" && {
            alert "Subdomain CORS bypass at $url — if you have XSS on any subdomain this is critical!"
            echo "CORS_SUBDOMAIN: $url" >> "$OUT/cors_vulns.txt"
        }
    done

    local vulns=$(wc -l < "$OUT/cors_vulns.txt" 2>/dev/null || echo 0)
    [ "$vulns" -gt 0 ] && alert "CORS vulns: $vulns"
    success "CORS check done."
}


# ════════════════════════════════════════════════════════════
#  14. 403 BYPASS
#  Edge case: a 403 is an invitation, not a dead end.
#  Header tricks + path normalization bypass it constantly.
# ════════════════════════════════════════════════════════════
bypass_403(){
    printf "\n" && info "403 Bypass Attempts for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/vulns"

    # Build a 403 URL list
    jq -r '.results[]? | select(.status==403) | .url' \
        "$OUTPUT_DIR/urls/ffuf.json" 2>/dev/null > "$OUT/403_urls.txt"

    # If empty, try common paths
    [ ! -s "$OUT/403_urls.txt" ] && {
        for path in admin administrator manager control panel dashboard backend api/v1/admin; do
            echo "https://$target/$path" >> "$OUT/403_urls.txt"
        done
    }

    step "Running bypass-403 tool..."
    require bypass-403 && while IFS= read -r url; do
        bypass-403 -u "$url" 2>/dev/null >> "$OUT/403_bypasses.txt"
    done < "$OUT/403_urls.txt"

    step "Header-based bypass attempts..."
    local bypass_headers=("X-Original-URL" "X-Rewrite-URL" "X-Custom-IP-Authorization"
                          "X-Forwarded-For" "X-Real-IP" "X-Originating-IP"
                          "X-Forwarded-Host" "X-Host" "X-Remote-IP" "X-Client-IP")

    while IFS= read -r url; do
        for header in "${bypass_headers[@]}"; do
            local code
            code=$(curl -s -o /dev/null -w "%{http_code}" \
                -H "$header: 127.0.0.1" "$url" 2>/dev/null)
            [ "$code" = "200" ] && {
                alert "403 BYPASS via $header at $url!"
                echo "HEADER_BYPASS [$header=127.0.0.1] → $url" >> "$OUT/403_bypasses.txt"
                notify "403 bypass via $header at $url!"
            }
        done

        step "Path normalization bypasses on $url..."
        for variant in \
            "${url}/" "${url}/./" "${url}/..;/" \
            "${url}%20" "${url}%09" "${url}%00" \
            "${url}#" "${url}?" "${url}/*" \
            "$(echo "$url" | sed 's|/\([^/]*\)$|/\U\1|g')" \
            "$(echo "$url" | sed 's|/\([^/]*\)$|/%2f\1|g')"; do
            local code
            code=$(curl -s -o /dev/null -w "%{http_code}" "$variant" 2>/dev/null)
            [ "$code" = "200" ] && {
                alert "403 PATH BYPASS: $variant"
                echo "PATH_BYPASS → $variant" >> "$OUT/403_bypasses.txt"
                notify "403 path bypass: $variant"
            }
        done
    done < "$OUT/403_urls.txt"

    success "403 bypass done. Check $OUT/403_bypasses.txt"
}


