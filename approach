# ════════════════════════════════════════════════════════════
#  1. ASN & IP RANGE DISCOVERY
#  Edge case: companies own IP ranges that never appear in DNS.
#  Internal tools, staging infra, forgotten apps live there.
# ════════════════════════════════════════════════════════════
asn_enum(){
    printf "\n" && info "ASN & IP Range Discovery for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/subdomains"
    local base="${target%%.*}"

    step "Querying BGPView for ASN..."
    curl -s "https://api.bgpview.io/search?query=$base" \
        | jq -r '.data.asns[]? | "\(.asn) \(.name) \(.description)"' 2>/dev/null \
        > "$OUT/asns.txt"

    if [ -s "$OUT/asns.txt" ]; then
        cat "$OUT/asns.txt"
        while IFS=' ' read -r asn rest; do
            step "Fetching IP ranges for AS$asn..."
            curl -s "https://api.bgpview.io/asn/$asn/prefixes" \
                | jq -r '.data.ipv4_prefixes[]?.prefix' 2>/dev/null \
                >> "$OUT/ip_ranges.txt"
        done < "$OUT/asns.txt"
        sort -u "$OUT/ip_ranges.txt" -o "$OUT/ip_ranges.txt"
        local ranges=$(wc -l < "$OUT/ip_ranges.txt")
        step "Total IP ranges owned by org: $ranges"
        alert "These ranges may contain infra that never shows up in DNS!"
    fi

    step "Reverse IP lookup (co-hosted domain discovery)..."
    local main_ip
    main_ip=$(dig +short "$target" A | head -1)
    if [ -n "$main_ip" ]; then
        curl -s "https://api.hackertarget.com/reverseiplookup/?q=$main_ip" \
            > "$OUT/reverse_ip_hosts.txt" 2>/dev/null
        local cohosted=$(wc -l < "$OUT/reverse_ip_hosts.txt")
        step "Co-hosted domains on same IP: $cohosted → $OUT/reverse_ip_hosts.txt"
    fi

    success "ASN enum done."
}


# ════════════════════════════════════════════════════════════
#  2. REVERSE WHOIS — FIND SIBLING DOMAINS
#  Edge case: M&A targets, sister companies, same registrant.
#  Same codebase, far less scrutiny.
# ════════════════════════════════════════════════════════════
reverse_whois(){
    printf "\n" && info "Reverse WHOIS for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/subdomains"

    step "Querying ViewDNS reverse WHOIS..."
    curl -s "https://viewdns.info/reversewhois/?q=${target}" \
        | grep -oP '(?<=<td>)[a-zA-Z0-9\-\.]+\.[a-zA-Z]{2,}(?=</td>)' \
        | sort -u > "$OUT/reverse_whois.txt" 2>/dev/null

    local found=$(wc -l < "$OUT/reverse_whois.txt" 2>/dev/null || echo 0)
    [ "$found" -gt 0 ] && {
        alert "Related domains via reverse WHOIS: $found"
        cat "$OUT/reverse_whois.txt"
        alert "These sibling domains often share infra and codebases — test them too!"
    }

    success "Reverse WHOIS done."
}


# ════════════════════════════════════════════════════════════
#  3. SUBDOMAIN ENUMERATION (7 SOURCES, PARALLEL)
# ════════════════════════════════════════════════════════════
subdomain_enum(){
    printf "\n" && info "Subdomain Enumeration at ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/subdomains"

    step "Running all sources in parallel..."
    require amass    && amass enum -passive -d "$target" -o "$OUT/amass.txt" 2>/dev/null &
    require subfinder && subfinder -d "$target" -all -recursive -silent -o "$OUT/subfinder.txt" 2>/dev/null &
    require assetfinder && assetfinder --subs-only "$target" > "$OUT/assetfinder.txt" 2>/dev/null &
    require findomain && findomain -t "$target" -u "$OUT/findomain.txt" 2>/dev/null &
    require chaos    && chaos -d "$target" -o "$OUT/chaos.txt" -silent 2>/dev/null &

    curl -s "https://crt.sh/?q=%25.$target&output=json" \
        | jq -r '.[].name_value' 2>/dev/null \
        | sed 's/\*\.//g' | sort -u > "$OUT/crtsh.txt" &

    curl -s "https://rapiddns.io/subdomain/$target?full=1" \
        | grep -oP "(?<=<td>)[a-zA-Z0-9\-\.]+\.$target(?=</td>)" \
        | sort -u > "$OUT/rapiddns.txt" 2>/dev/null &

    curl -s "https://otx.alienvault.com/api/v1/indicators/domain/$target/passive_dns" \
        | jq -r '.passive_dns[]?.hostname' 2>/dev/null \
        | sort -u > "$OUT/otx.txt" 2>/dev/null &

    wait

    cat "$OUT"/*.txt 2>/dev/null | sort -u > "$OUT/all_subs_raw.txt"
    local total=$(wc -l < "$OUT/all_subs_raw.txt")
    step "Total unique raw subdomains: $total"

    step "Resolving with puredns (wildcard-aware)..."
    require puredns && puredns resolve "$OUT/all_subs_raw.txt" \
        --resolvers "$RESOLVERS" -w "$OUT/resolved.txt" 2>/dev/null

    step "Wildcard DNS check (false positive trap)..."
    local wildcard
    wildcard=$(dig +short "$(openssl rand -hex 8).$target" A 2>/dev/null)
    [ -n "$wildcard" ] && warn "Wildcard DNS detected ($wildcard) — passive results need careful verification!"

    step "HTTP probing live hosts..."
    require httpx && httpx -l "$OUT/resolved.txt" \
        -title -tech-detect -status-code -content-length -ip -cdn \
        -ports 80,443,8080,8443,8888,3000,4000,5000,9000 \
        -threads "$THREADS" -silent \
        -o "$OUT/live_hosts.txt" 2>/dev/null

    local live=$(wc -l < "$OUT/live_hosts.txt")
    success "Raw: $total | Live: $live → $OUT/live_hosts.txt"
}


# ════════════════════════════════════════════════════════════
#  4. PERMUTATION-BASED SUBDOMAIN DISCOVERY
#  Edge case: dev.target.com, api-v2.target.com, us-prod.target.com
#  Never appear in passive enumeration. This finds them.
# ════════════════════════════════════════════════════════════
permutation_enum(){
    printf "\n" && info "Permutation Subdomain Discovery for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/subdomains"
    local RESOLVED="$OUT/resolved.txt"

    [ ! -f "$RESOLVED" ] && warn "Run -sb first." && return 1

    step "Generating permutations with alterx..."
    if require alterx; then
        cat "$RESOLVED" | alterx -en \
            -pp "word=dev,api,api-v2,api-v3,staging,prod,internal,admin,test,uat,qa,beta,alpha,sandbox,vault,git,ci,cd,jenkins,grafana,kibana,elastic,db,mysql,redis,mongo,s3,backup,old,legacy,new,shop,mobile,app,portal,dashboard,manager,control,panel,status,health,metrics,us,eu,aws,gcp,corp,vpn,mail,smtp,ftp,secure,login,auth" \
            -o "$OUT/permuted.txt" 2>/dev/null
        local pcount=$(wc -l < "$OUT/permuted.txt")
        step "Generated $pcount permutations"
    fi

    require goaltdns && goaltdns -l "$RESOLVED" \
        -w /path/to/goaltdns_wordlist.txt \
        -o "$OUT/goaltdns.txt" 2>/dev/null
    cat "$OUT/goaltdns.txt" >> "$OUT/permuted.txt" 2>/dev/null
    sort -u "$OUT/permuted.txt" -o "$OUT/permuted.txt"

    step "Resolving permutations..."
    require puredns && puredns resolve "$OUT/permuted.txt" \
        --resolvers "$RESOLVERS" -w "$OUT/permuted_resolved.txt" 2>/dev/null

    step "Finding NET-NEW subdomains (not in original passive enum)..."
    if [ -f "$OUT/permuted_resolved.txt" ] && [ -f "$RESOLVED" ]; then
        comm -23 \
            <(sort "$OUT/permuted_resolved.txt") \
            <(sort "$RESOLVED") \
            > "$OUT/permuted_new_only.txt"
        local newcount=$(wc -l < "$OUT/permuted_new_only.txt")
        [ "$newcount" -gt 0 ] && {
            alert "Found $newcount NEW subdomains via permutation that passive enum missed!"
            notify "Permutation found $newcount new subdomains not in passive enum!"
        }
    fi

    success "Permutation done."
}


# ════════════════════════════════════════════════════════════
#  5. DNS DEEP ANALYSIS
#  Edge case: zone transfers, SPF misconfigs, DMARC absence,
#  dangling CNAMEs, wildcard detection.
# ════════════════════════════════════════════════════════════
dns_analysis(){
    printf "\n" && info "DNS Deep Analysis for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/dns"

    step "Full DNS record dump..."
    for rtype in A AAAA CNAME MX NS TXT SOA CAA; do
        echo "--- $rtype ---" >> "$OUT/dns_records.txt"
        dig +short "$target" "$rtype" 2>/dev/null >> "$OUT/dns_records.txt"
    done

    step "DNS Zone Transfer (AXFR) attempts on all nameservers..."
    dig +short NS "$target" 2>/dev/null | while IFS= read -r ns; do
        [ -z "$ns" ] && continue
        result=$(dig AXFR "@$ns" "$target" 2>/dev/null)
        if echo "$result" | grep -qv "Transfer failed\|connection timed out\|communications error"; then
            if echo "$result" | grep -q "SOA"; then
                alert "ZONE TRANSFER SUCCEEDED on $ns — critical finding!"
                echo "$result" > "$OUT/zone_transfer_${ns}.txt"
                notify "CRITICAL: Zone transfer succeeded on $ns for $target!"
            fi
        else
            step "AXFR failed on $ns (expected)"
        fi
    done

    step "SPF record check..."
    local spf
    spf=$(dig +short TXT "$target" 2>/dev/null | grep "v=spf1")
    if [ -z "$spf" ]; then
        alert "No SPF record — email spoofing possible!"
        echo "NO_SPF" >> "$OUT/email_issues.txt"
        notify "No SPF on $target — email spoofing risk!"
    else
        echo "SPF: $spf" >> "$OUT/email_security.txt"
        echo "$spf" | grep -q "+all" && alert "SPF uses +all — anyone can send as this domain!"
        echo "$spf" | grep -q "~all" && warn "SPF uses ~all (softfail) — weak protection."
    fi

    step "DMARC check..."
    local dmarc
    dmarc=$(dig +short TXT "_dmarc.$target" 2>/dev/null)
    if [ -z "$dmarc" ]; then
        alert "No DMARC record — phishing/spoofing risk!"
        echo "NO_DMARC" >> "$OUT/email_issues.txt"
    else
        echo "DMARC: $dmarc" >> "$OUT/email_security.txt"
        echo "$dmarc" | grep -q "p=none" && warn "DMARC policy=none — monitoring only, not enforcing!"
    fi

    step "DKIM check (common selectors)..."
    for selector in default google mail dkim smtp selector1 selector2 k1 s1 s2; do
        local dkim
        dkim=$(dig +short TXT "${selector}._domainkey.$target" 2>/dev/null)
        [ -n "$dkim" ] && echo "DKIM ($selector): $dkim" >> "$OUT/email_security.txt"
    done

    step "Dangling CNAME check (takeover signals)..."
    if [ -f "$OUTPUT_DIR/subdomains/resolved.txt" ]; then
        dnsx -l "$OUTPUT_DIR/subdomains/resolved.txt" \
            -cname -resp -silent 2>/dev/null \
            | grep -iE "github\.io|heroku|shopify|azure|s3\.amazonaws|cloudfront|fastly|pantheon|netlify|surge\.sh|readme\.io|statuspage\.io|uservoice\.com|ghost\.io|intercom\.io" \
            > "$OUT/dangling_cnames.txt" 2>/dev/null
        local tkos=$(wc -l < "$OUT/dangling_cnames.txt" 2>/dev/null || echo 0)
        [ "$tkos" -gt 0 ] && {
            alert "Dangling CNAME takeover candidates: $tkos"
            notify "Dangling CNAMEs found — potential takeovers: $tkos"
        }
    fi

    success "DNS analysis done. Check $OUT/"
}


# ════════════════════════════════════════════════════════════
#  6. WAF & TECH FINGERPRINTING
#  Edge case: knowing the WAF before attacking saves hours.
#  Favicon hash lets you find OTHER instances of the same
#  app on Shodan — including unprotected ones.
# ════════════════════════════════════════════════════════════
waf_detect(){
    printf "\n" && info "WAF & Technology Fingerprint for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/waf"

    step "WAF detection with wafw00f..."
    require wafw00f && wafw00f "https://$target" -a -o "$OUT/wafw00f.txt" 2>/dev/null
    grep -i "is behind" "$OUT/wafw00f.txt" 2>/dev/null && alert "WAF detected — check WAF-bypass payloads!"

    step "Security header analysis..."
    curl -s -I "https://$target" 2>/dev/null > "$OUT/headers.txt"
    local missing_headers=()
    for header in "Strict-Transport-Security" "Content-Security-Policy" \
                  "X-Frame-Options" "X-Content-Type-Options" \
                  "Referrer-Policy" "Permissions-Policy"; do
        grep -qi "$header" "$OUT/headers.txt" || missing_headers+=("$header")
    done
    [ ${#missing_headers[@]} -gt 0 ] && {
        warn "Missing security headers: ${missing_headers[*]}"
        printf "%s\n" "${missing_headers[@]}" > "$OUT/missing_headers.txt"
    }

    step "Favicon hash (for Shodan search)..."
    python3 - <<PYEOF 2>/dev/null > "$OUT/favicon.txt"
import requests, base64, sys
try:
    import mmh3
except ImportError:
    sys.exit(0)
try:
    r = requests.get("https://$target/favicon.ico", timeout=8, verify=False)
    if r.status_code == 200:
        h = mmh3.hash(base64.encodebytes(r.content))
        print(f"Favicon mmh3 hash: {h}")
        print(f"Shodan dork: http.favicon.hash:{h}")
        print("Use this on Shodan to find other instances of this app — including unprotected ones!")
except: pass
PYEOF
    [ -s "$OUT/favicon.txt" ] && cat "$OUT/favicon.txt"

    step "Full tech fingerprint with whatweb..."
    require whatweb && whatweb "https://$target" \
        --log-json="$OUT/whatweb.json" 2>/dev/null

    success "WAF/tech done. Check $OUT/"
}


# ════════════════════════════════════════════════════════════
#  7. PORT SCANNING (ELITE — ALL OWNED IPs)
# ════════════════════════════════════════════════════════════
port_scan(){
    printf "\n" && info "Port Scanning for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/ports"

    step "Collecting all unique IPs (subdomains + ASN ranges)..."
    if [ -f "$OUTPUT_DIR/subdomains/resolved.txt" ]; then
        dnsx -l "$OUTPUT_DIR/subdomains/resolved.txt" \
            -a -resp-only -silent 2>/dev/null | sort -u > "$OUT/all_ips.txt"
    else
        dig +short "$target" A | sort -u > "$OUT/all_ips.txt"
    fi
    [ -f "$OUTPUT_DIR/subdomains/ip_ranges.txt" ] && \
        cat "$OUTPUT_DIR/subdomains/ip_ranges.txt" >> "$OUT/all_ips.txt"
    sort -u "$OUT/all_ips.txt" -o "$OUT/all_ips.txt"

    local ipcount=$(wc -l < "$OUT/all_ips.txt")
    step "Scanning $ipcount unique IPs with naabu..."

    require naabu && naabu -list "$OUT/all_ips.txt" \
        -p 21,22,23,25,53,69,80,110,111,135,139,143,389,443,445,465,500,587,631,636,873,\
993,995,1080,1099,1194,1433,1521,1723,2049,2082,2083,2086,2087,2095,2096,2181,\
2375,2376,3000,3001,3128,3268,3269,3306,3389,3690,4000,4001,4243,4369,4848,\
5000,5432,5601,5672,5900,5984,6379,6443,7001,7002,7070,7077,7080,7443,7474,\
8000,8001,8008,8080,8081,8083,8084,8085,8088,8089,8090,8161,8443,8444,8888,\
9000,9001,9090,9092,9200,9300,9418,9443,10000,11211,15672,25565,27017,28017,\
50000,50070,50075,61616 \
        -silent -rate 1000 -o "$OUT/naabu_open.txt" 2>/dev/null

    step "Service/version detection with nmap on confirmed open ports..."
    if [ -s "$OUT/naabu_open.txt" ]; then
        awk -F: '{print $1}' "$OUT/naabu_open.txt" | sort -u > "$OUT/ips_with_open.txt"
        local open_ports
        open_ports=$(awk -F: '{print $2}' "$OUT/naabu_open.txt" | sort -un | tr '\n' ',' | sed 's/,$//')
        require nmap && nmap -Pn -sV -sC \
            -p "$open_ports" \
            -iL "$OUT/ips_with_open.txt" \
            --open --min-rate 1000 \
            -oN "$OUT/nmap_services.txt" 2>/dev/null
    fi

    step "HTTP probe on non-standard ports..."
    cat "$OUT/naabu_open.txt" 2>/dev/null | httpx \
        -title -status-code -tech-detect \
        -threads "$THREADS" -silent \
        -o "$OUT/nonstandard_http.txt" 2>/dev/null

    step "Alerting on critical exposures..."
    declare -A juicy=([9200]="Elasticsearch" [6379]="Redis" [27017]="MongoDB"
                      [5984]="CouchDB" [9092]="Kafka" [2375]="Docker-unauthenticated"
                      [5601]="Kibana" [7474]="Neo4j" [4369]="RabbitMQ"
                      [11211]="Memcached" [50070]="Hadoop" [2181]="Zookeeper")
    for port in "${!juicy[@]}"; do
        grep -q ":$port$" "$OUT/naabu_open.txt" 2>/dev/null && {
            alert "EXPOSED: ${juicy[$port]} on port $port!"
            notify "CRITICAL: ${juicy[$port]} exposed (port $port) at $target!"
        }
    done

    success "Port scan done. Check $OUT/"
}


# ════════════════════════════════════════════════════════════
#  8. URL HARVESTING
# ════════════════════════════════════════════════════════════
url_harvest(){
    printf "\n" && info "URL Harvesting for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/urls"

    step "Historical URLs via gau (wayback + commoncrawl + otx)..."
    require gau && echo "$target" | gau \
        --subs --threads "$THREADS" \
        --o "$OUT/gau_urls.txt" 2>/dev/null

    require waybackurls && echo "$target" | waybackurls \
        > "$OUT/wayback_urls.txt" 2>/dev/null

    step "Active crawl with katana (JS-rendering)..."
    require katana && katana -u "https://$target" \
        -jc -fx -kf all -d 5 \
        -silent -threads "$THREADS" \
        -o "$OUT/katana_urls.txt" 2>/dev/null

    step "Merging + dedup with uro..."
    cat "$OUT/gau_urls.txt" "$OUT/wayback_urls.txt" "$OUT/katana_urls.txt" 2>/dev/null \
        | sort -u | uro > "$OUT/all_urls.txt" 2>/dev/null

    step "Extracting parameterized URLs..."
    grep "?" "$OUT/all_urls.txt" 2>/dev/null \
        | sed 's/=.*/=/' | sort -u > "$OUT/param_urls.txt"

    step "Hunting juicy file extensions..."
    grep -iE "\.(bak|backup|old|orig|config|conf|cfg|env|log|sql|db|sqlite|xml|json|yaml|yml|zip|tar|gz|rar|7z|dump|secret|key|pem|crt|cer|php~|swp|save)$" \
        "$OUT/all_urls.txt" 2>/dev/null > "$OUT/interesting_extensions.txt"
    local ext=$(wc -l < "$OUT/interesting_extensions.txt")
    [ "$ext" -gt 0 ] && {
        alert "Juicy file extensions found: $ext URLs"
        notify "Juicy file extensions: $ext URLs at $target"
    }

    step "Extracting API paths..."
    grep -iE "/api/|/v[0-9]+/|/rest/|/graphql|/gql" \
        "$OUT/all_urls.txt" 2>/dev/null | sort -u > "$OUT/api_paths.txt"

    local total=$(wc -l < "$OUT/all_urls.txt")
    local params=$(wc -l < "$OUT/param_urls.txt")
    success "Total URLs: $total | With params: $params"
}


# ════════════════════════════════════════════════════════════
#  9. JAVASCRIPT DEEP ANALYSIS
#  Edge case: scan HISTORICAL JS from Wayback too — secrets
#  that were "deleted" months ago are still in archive.
# ════════════════════════════════════════════════════════════
javascript(){
    printf "\n" && info "JavaScript Analysis for ${RED}$target${RST}"
    local OUT="$OUTPUT_DIR/js"
    mkdir -p "$OUT/downloads"

    step "Crawling with katana..."
    require katana && katana -u "https://$target" \
        -jc -fx -kf all -d 5 -silent \
        -o "$OUT/katana_urls.txt" 2>/dev/null

    step "Filtering and downloading JS files (excluding vendor/library files)..."
    grep "\.js$" "$OUT/katana_urls.txt" 2>/dev/null \
        | grep -v "node_modules\|jquery\|bootstrap\|lodash\|react\.min\|angular\.min\|vendor\|chunk" \
        | sort -u > "$OUT/js_urls.txt"

    while IFS= read -r url; do
        local fname
        fname=$(echo "$url" | md5sum | cut -d' ' -f1)
        wget -q "$url" -O "$OUT/downloads/${fname}.js" 2>/dev/null
    done < "$OUT/js_urls.txt"

    step "HISTORICAL JS from Wayback (deleted secrets goldmine)..."
