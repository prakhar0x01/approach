    step "Org search..."
    shodan search --fields ip_str,port,hostnames,org,os \
        "org:\"$target\"" 2>/dev/null | head -100 > "$OUT/shodan_org.txt"

    step "SSL cert CN search (finds internal domain names)..."
    shodan search --fields ip_str,port,ssl.cert.subject.cn \
        "ssl.cert.subject.cn:\"$target\"" 2>/dev/null > "$OUT/shodan_ssl.txt"

    step "SAN search (Subject Alternative Names reveal internal infra)..."
    shodan search --fields ip_str,port,ssl.cert.extensions.subjectAltName \
        "ssl.cert.extensions.subjectAltName:\"$target\"" 2>/dev/null > "$OUT/shodan_san.txt"

    step "Historical host data on main IP..."
    local main_ip
    main_ip=$(dig +short "$target" A | head -1)
    [ -n "$main_ip" ] && shodan host "$main_ip" 2>/dev/null > "$OUT/shodan_host.txt"

    step "Favicon hash search (if computed)..."
    if [ -f "$OUTPUT_DIR/waf/favicon.txt" ]; then
        local fhash
        fhash=$(grep "mmh3 hash" "$OUTPUT_DIR/waf/favicon.txt" | grep -oP '\-?[0-9]+')
        [ -n "$fhash" ] && {
            step "Searching Shodan for favicon hash: $fhash..."
            shodan search --fields ip_str,port,hostnames \
                "http.favicon.hash:$fhash" 2>/dev/null > "$OUT/shodan_favicon.txt"
            local fi_count=$(wc -l < "$OUT/shodan_favicon.txt")
            [ "$fi_count" -gt 1 ] && alert "Found $fi_count instances of this app on Shodan via favicon hash!"
        }
    fi

    success "Shodan done. Check $OUT/shodan_*.txt"
}


