generate_report(){
    printf "\n" && info "Generating Recon Report..."
    local R="$OUTPUT_DIR/report/recon_report.md"

    local total_subs=$(wc -l < "$OUTPUT_DIR/subdomains/all_subs_raw.txt" 2>/dev/null || echo "N/A")
    local live=$(wc -l < "$OUTPUT_DIR/subdomains/live_hosts.txt" 2>/dev/null || echo "N/A")
    local urls=$(wc -l < "$OUTPUT_DIR/urls/all_urls.txt" 2>/dev/null || echo "N/A")
    local open_ports=$(wc -l < "$OUTPUT_DIR/ports/naabu_open.txt" 2>/dev/null || echo "N/A")
    local nuclei=$(cat "$OUTPUT_DIR/vulns/nuclei_sweep.txt" "$OUTPUT_DIR/vulns/nuclei_cves.txt" 2>/dev/null | wc -l)
    local takeovers=$(grep -c "VULNERABLE\|vulnerable" "$OUTPUT_DIR/vulns/subzy.txt" 2>/dev/null || echo 0)
    local cors=$(wc -l < "$OUTPUT_DIR/cors/cors_vulns.txt" 2>/dev/null || echo 0)
    local secrets=$(wc -l < "$OUTPUT_DIR/js/secrets.txt" 2>/dev/null || echo 0)
    local bypasses=$(wc -l < "$OUTPUT_DIR/vulns/403_bypasses.txt" 2>/dev/null || echo 0)
    local cloud=$(wc -l < "$OUTPUT_DIR/cloud/cloud_interesting.txt" 2>/dev/null || echo 0)

    cat > "$R" <<REPORT
# Recon Report — $target
**Date:** $(date)

---

## Stats
| Metric | Count |
|---|---|
| Subdomains found | $total_subs |
| Live hosts | $live |
| URLs harvested | $urls |
| Open ports | $open_ports |

## Findings
| Category | Count |
|---|---|
| Nuclei findings | $nuclei |
| Subdomain takeovers | $takeovers |
| CORS misconfigurations | $cors |
| JS/Git secrets | $secrets |
| 403 bypasses | $bypasses |
| Open cloud buckets | $cloud |

---

## Live Hosts (top 30)
\`\`\`
$(head -30 "$OUTPUT_DIR/subdomains/live_hosts.txt" 2>/dev/null)
\`\`\`

## Critical/High Nuclei Findings
\`\`\`
$(grep -E "\[critical\]|\[high\]" "$OUTPUT_DIR/vulns/nuclei_sweep.txt" "$OUTPUT_DIR/vulns/nuclei_cves.txt" 2>/dev/null | head -20 || echo "none")
\`\`\`

## Interesting Panels
\`\`\`
$(cat "$OUTPUT_DIR/urls/interesting_panels.txt" 2>/dev/null || echo "none")
\`\`\`

## GF Pattern Candidates
$(cat "$OUTPUT_DIR/patterns/gf_summary.txt" 2>/dev/null || echo "run -gf first")

## Email Security Issues
\`\`\`
$(cat "$OUTPUT_DIR/dns/email_issues.txt" 2>/dev/null || echo "none")
\`\`\`

## DNS Anomalies
\`\`\`
$(cat "$OUTPUT_DIR/dns/dangling_cnames.txt" 2>/dev/null | head -10 || echo "none")
\`\`\`

---

## Next Steps Checklist
- [ ] Manually investigate all critical/high nuclei findings
- [ ] Test all gf pattern URLs for actual vulnerabilities
- [ ] Test CORS vulns with an authenticated session
- [ ] Check 403 bypasses manually — confirm access
- [ ] Test interesting panels for default creds / logic flaws
- [ ] Verify subdomain takeover candidates
- [ ] Review all secrets and validate they work
- [ ] Run AI triage: ./approach.sh -triage $target

---
*Generated by approach.sh v3.0 | $(date)*
REPORT

    success "Report → $R"
    echo ""
    echo -e "  ${GRN}Output summary:${RST}"
    echo -e "  Subdomains    → $OUTPUT_DIR/subdomains/"
    echo -e "  Live Hosts    → $OUTPUT_DIR/subdomains/live_hosts.txt"
    echo -e "  URLs + Params → $OUTPUT_DIR/urls/"
    echo -e "  GF Patterns   → $OUTPUT_DIR/patterns/gf_*.txt"
    echo -e "  JS Secrets    → $OUTPUT_DIR/js/secrets.txt"
    echo -e "  Ports         → $OUTPUT_DIR/ports/"
    echo -e "  CORS Vulns    → $OUTPUT_DIR/cors/cors_vulns.txt"
    echo -e "  403 Bypasses  → $OUTPUT_DIR/vulns/403_bypasses.txt"
    echo -e "  Takeovers     → $OUTPUT_DIR/vulns/subzy.txt"
    echo -e "  Nuclei        → $OUTPUT_DIR/vulns/"
