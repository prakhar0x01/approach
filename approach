    echo -e "  DNS Analysis  → $OUTPUT_DIR/dns/"
    echo -e "  WAF/Headers   → $OUTPUT_DIR/waf/"
    echo -e "  Report        → $OUTPUT_DIR/report/recon_report.md"
}


